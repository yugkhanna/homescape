{
  "brand_identity": {
    "name": "HomeScape Group Pvt Ltd",
    "tagline": "Powering Supply, Enabling Growth",
    "archetype": "The Performance Pro",
    "emotional_tone": "Authoritative, Precise, Industrial, Kinetic",
    "visual_mood": "High-Contrast, Tech-Industrial, Clean, Dense"
  },
  "typography": {
    "primary_font": {
      "name": "Barlow Condensed",
      "weights": ["400", "500", "600", "700", "900"],
      "usage": "Headings, Hero Text, Data Points",
      "cdn_import": "@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;900&family=Inter:wght@300;400;500;600&display=swap');"
    },
    "secondary_font": {
      "name": "Inter",
      "weights": ["300", "400", "500", "600"],
      "usage": "Body text, Navigation, Button labels"
    },
    "rules": [
      "Headings: Uppercase, tracking-tight, leading-none",
      "Body: tracking-wide, leading-relaxed",
      "Labels: Uppercase, tracking-widest, text-xs"
    ]
  },
  "colors": {
    "palette": {
      "primary": "#020617",
      "primary_foreground": "#FFFFFF",
      "secondary": "#f97316",
      "secondary_foreground": "#FFFFFF",
      "accent": "#f8fafc",
      "accent_foreground": "#0f172a",
      "neutral": "#64748b",
      "border": "#1e293b",
      "input": "#1e293b"
    },
    "surface_strategies": [
      "glassmorphism_header",
      "solid_matte_cards",
      "grid_lines_background"
    ],
    "gradients": {
      "hero_overlay": "linear-gradient(to bottom, rgba(2,6,23,0.3), rgba(2,6,23,0.95))",
      "orange_glow": "radial-gradient(circle at center, rgba(249,115,22,0.15) 0%, rgba(249,115,22,0) 70%)"
    }
  },
  "layout_strategies": {
    "container": "max-w-7xl mx-auto px-6 md:px-12",
    "spacing_scale": {
      "section_gap": "py-24 md:py-32",
      "element_gap": "gap-8",
      "internal_padding": "p-8 md:p-12"
    },
    "grid_system": "Bento Grid Mode A (Asymmetrical)",
    "z_index": {
      "header": 50,
      "modal": 100,
      "content": 10,
      "background": 0
    }
  },
  "components": {
    "header": {
      "type": "Sticky Glassmorphism",
      "classes": "fixed top-0 left-0 right-0 z-50 bg-slate-950/80 backdrop-blur-md border-b border-white/10",
      "height": "h-20",
      "logo_text": "text-white font-black tracking-tighter text-2xl uppercase",
      "nav_links": "text-sm font-medium text-slate-300 hover:text-orange-500 transition-colors uppercase tracking-widest"
    },
    "hero": {
      "layout": "Full Screen with Overlay",
      "text_align": "text-center md:text-left",
      "h1_size": "text-6xl md:text-8xl lg:text-9xl",
      "cta_button": "bg-orange-500 hover:bg-orange-600 text-white font-bold uppercase tracking-wider px-8 py-4 rounded-none clip-path-slant"
    },
    "verticals_grid": {
      "style": "Bento Grid",
      "card_style": "group relative overflow-hidden bg-slate-900 border border-slate-800 hover:border-orange-500/50 transition-all duration-500",
      "hover_effect": "group-hover:scale-105 transition-transform duration-700"
    },
    "marquee": {
      "library": "react-fast-marquee",
      "style": "grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
    },
    "contact_form": {
      "library": "shadcn/ui form",
      "style": "bg-slate-900/50 border border-slate-800 p-8 rounded-none",
      "input_style": "bg-slate-950 border-slate-800 focus:border-orange-500 rounded-none h-12"
    }
  },
