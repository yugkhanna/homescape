  },
  "motion_guidelines": {
    "library": "framer-motion",
    "animations": {
      "fadeInUp": {
        "initial": { "opacity": 0, "y": 40 },
        "whileInView": { "opacity": 1, "y": 0 },
        "viewport": { "once": true },
        "transition": { "duration": 0.8, "ease": "easeOut" }
      },
      "staggerContainer": {
        "hidden": { "opacity": 0 },
        "show": {
          "opacity": 1,
          "transition": {
            "staggerChildren": 0.1
          }
        }
      }
    }
  },
  "universal_guidelines": [
    "Do not use generic gradients. Use deep solid colors with subtle noise or 1px borders.",
    "Use 2-3x more spacing than typical designs (e.g., py-32 for sections).",
    "Typography: Headings must be uppercase and condensed. Body must be clean sans-serif.",
    "Buttons: Square or slightly rounded (2px). No pill shapes for this industrial brand.",
    "All interactive elements must have data-testid attributes."
  ],
  "instructions_to_main_agent": [
    "Install 'react-fast-marquee' and 'framer-motion' using yarn.",
    "Import Barlow Condensed and Inter fonts in index.css.",
    "Update tailwind.config.js to include the new fonts and colors.",
    "Build the components in this order: Header -> Hero -> About -> Verticals (Bento) -> Partners -> Contact -> Footer.",
    "Use the specific image URLs provided for each section.",
    "Ensure the contact form uses 'zod' for validation but does not require a backend (show success toast).",
    "Use 'lucide-react' for icons."
  ]
}